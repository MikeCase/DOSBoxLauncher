                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Scaler</property></object><packing><property name="left-attach">0</property><property name="top-attach">2</property></packing></child>
                                <child><object class="GtkComboBoxText" id="scaler_cbox"><property name="visible">True</property><items><item translatable="yes">none</item><item translatable="yes">normal2x</item><item translatable="yes">normal3x</item><item translatable="yes">advmame2x</item><item translatable="yes">advmame3x</item><item translatable="yes">advinterp2x</item><item translatable="yes">advinterp3x</item><item translatable="yes">hq2x</item><item translatable="yes">hq3x</item><item translatable="yes">2xsai</item><item translatable="yes">super2xsai</item><item translatable="yes">supereagle</item><item translatable="yes">tv2x</item><item translatable="yes">tv3x</item><item translatable="yes">rgb2x</item><item translatable="yes">rgb3x</item><item translatable="yes">scan2x</item><item translatable="yes">scan3x</item></items></object><packing><property name="left-attach">1</property><property name="top-attach">2</property></packing></child>
                              </object>
                            </child>
