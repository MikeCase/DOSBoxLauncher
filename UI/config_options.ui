                                <property name="column-spacing">16</property>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Frameskip</property></object><packing><property name="left-attach">0</property><property name="top-attach">0</property></packing></child>
