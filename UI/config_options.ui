<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.24"/>

  <object class="GtkTextBuffer" id="autoexec_tbuffer"/>

  <object class="GtkWindow" id="OptsWindow">
    <property name="can-focus">False</property>
    <property name="default-width">960</property>
    <property name="default-height">620</property>
    <child>
      <object class="GtkBox">
        <property name="visible">True</property>
        <property name="can-focus">False</property>
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <property name="margin-start">12</property>
        <property name="margin-end">12</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">12</property>
        <child>
          <object class="GtkLabel">
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="xalign">0</property>
            <property name="label" translatable="yes">DOSBox Configuration Editor</property>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="position">0</property>
          </packing>
        </child>
        <child>
          <object class="GtkNotebook">
            <property name="visible">True</property>
            <property name="can-focus">True</property>
            <property name="scrollable">True</property>

            <child>
              <object class="GtkScrolledWindow">
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="shadow-type">etched-in</property>
                <child>
                  <object class="GtkViewport">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <child>
                      <object class="GtkBox">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="orientation">vertical</property>
                        <property name="spacing">12</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <property name="margin-top">12</property>
                        <property name="margin-bottom">12</property>
                        <child>
                          <object class="GtkFrame">
                            <property name="visible">True</property>
                            <property name="label-xalign">0</property>
                            <property name="label" translatable="yes">Display and Input</property>
                            <child>
                              <object class="GtkGrid">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property name="border-width">12</property>
                                <property name="row-spacing">10</property>
                                <property name="column-spacing">16</property>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Fullscreen</property></object><packing><property name="left-attach">0</property><property name="top-attach">0</property></packing></child>
                                <child><object class="GtkSwitch" id="fullscreen_sw"><property name="visible">True</property><property name="halign">end</property></object><packing><property name="left-attach">1</property><property name="top-attach">0</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Double Buffering</property></object><packing><property name="left-attach">0</property><property name="top-attach">1</property></packing></child>
                                <child><object class="GtkSwitch" id="fulldouble_sw"><property name="visible">True</property><property name="halign">end</property></object><packing><property name="left-attach">1</property><property name="top-attach">1</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Fullscreen Resolution</property></object><packing><property name="left-attach">0</property><property name="top-attach">2</property></packing></child>
                                <child><object class="GtkComboBoxText" id="full_resolution_cbox"><property name="visible">True</property><property name="halign">fill</property><items><item translatable="yes">original</item><item translatable="yes">desktop</item><item translatable="yes">640x480</item><item translatable="yes">800x600</item><item translatable="yes">1024x768</item><item translatable="yes">1280x720</item><item translatable="yes">1920x1024</item></items></object><packing><property name="left-attach">1</property><property name="top-attach">2</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Window Resolution</property></object><packing><property name="left-attach">0</property><property name="top-attach">3</property></packing></child>
                                <child><object class="GtkComboBoxText" id="wind_res_cbox"><property name="visible">True</property><property name="halign">fill</property><items><item translatable="yes">original</item><item translatable="yes">desktop</item><item translatable="yes">640x480</item><item translatable="yes">800x600</item><item translatable="yes">1024x768</item><item translatable="yes">1280x720</item><item translatable="yes">1920x1024</item></items></object><packing><property name="left-attach">1</property><property name="top-attach">3</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Output</property></object><packing><property name="left-attach">0</property><property name="top-attach">4</property></packing></child>
                                <child><object class="GtkComboBoxText" id="output_cbox"><property name="visible">True</property><property name="halign">fill</property><items><item translatable="yes">surface</item><item translatable="yes">overlay</item><item translatable="yes">opengl</item><item translatable="yes">openglnb</item></items></object><packing><property name="left-attach">1</property><property name="top-attach">4</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Auto Lock Mouse</property></object><packing><property name="left-attach">0</property><property name="top-attach">5</property></packing></child>
                                <child><object class="GtkSwitch" id="autolock_sw"><property name="visible">True</property><property name="halign">end</property></object><packing><property name="left-attach">1</property><property name="top-attach">5</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Mouse Sensitivity</property></object><packing><property name="left-attach">0</property><property name="top-attach">6</property></packing></child>
                                <child><object class="GtkSpinButton" id="sensitivity_spin"><property name="visible">True</property><property name="halign">end</property><property name="adjustment">sensitivity_adj</property><property name="numeric">True</property></object><packing><property name="left-attach">1</property><property name="top-attach">6</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Wait on Error</property></object><packing><property name="left-attach">0</property><property name="top-attach">7</property></packing></child>
                                <child><object class="GtkSwitch" id="wait_on_error_sw"><property name="visible">True</property><property name="halign">end</property></object><packing><property name="left-attach">1</property><property name="top-attach">7</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Priority</property></object><packing><property name="left-attach">0</property><property name="top-attach">8</property></packing></child>
                                <child><object class="GtkComboBoxText" id="priority_cbox"><property name="visible">True</property><items><item translatable="yes">higher,normal</item><item translatable="yes">normal,normal</item><item translatable="yes">higher,pause</item></items></object><packing><property name="left-attach">1</property><property name="top-attach">8</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Mapper File</property></object><packing><property name="left-attach">0</property><property name="top-attach">9</property></packing></child>
                                <child><object class="GtkEntry" id="mapper_file_entry"><property name="visible">True</property></object><packing><property name="left-attach">1</property><property name="top-attach">9</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Use Scan Codes</property></object><packing><property name="left-attach">0</property><property name="top-attach">10</property></packing></child>
                                <child><object class="GtkSwitch" id="use_scan_codes_sw"><property name="visible">True</property><property name="halign">end</property></object><packing><property name="left-attach">1</property><property name="top-attach">10</property></packing></child>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkFrame">
                            <property name="visible">True</property>
                            <property name="label-xalign">0</property>
                            <property name="label" translatable="yes">DOSBox Core</property>
                            <child>
                              <object class="GtkGrid">
                                <property name="visible">True</property>
                                <property name="can-focus">False</property>
                                <property name="border-width">12</property>
                                <property name="row-spacing">10</property>
                                <property name="column-spacing">16</property>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Language File</property></object><packing><property name="left-attach">0</property><property name="top-attach">0</property></packing></child>
                                <child><object class="GtkEntry" id="language_entry"><property name="visible">True</property></object><packing><property name="left-attach">1</property><property name="top-attach">0</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Machine Type</property></object><packing><property name="left-attach">0</property><property name="top-attach">1</property></packing></child>
                                <child><object class="GtkComboBoxText" id="machine_cbox"><property name="visible">True</property><items><item translatable="yes">hercules</item><item translatable="yes">cga</item><item translatable="yes">tandy</item><item translatable="yes">pcjr</item><item translatable="yes">ega</item><item translatable="yes">vgaonly</item><item translatable="yes">svga_s3</item><item translatable="yes">svga_et3000</item><item translatable="yes">svga_et4000</item><item translatable="yes">svga_paradise</item><item translatable="yes">vesa_nofb</item><item translatable="yes">vesa_oldvbe</item></items></object><packing><property name="left-attach">1</property><property name="top-attach">1</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Captures Directory</property></object><packing><property name="left-attach">0</property><property name="top-attach">2</property></packing></child>
                                <child><object class="GtkEntry" id="captures_entry"><property name="visible">True</property></object><packing><property name="left-attach">1</property><property name="top-attach">2</property></packing></child>
                                <child><object class="GtkLabel"><property name="visible">True</property><property name="halign">start</property><property name="label" translatable="yes">Memory Size (MB)</property></object><packing><property name="left-attach">0</property><property name="top-attach">3</property></packing></child>
                                <child><object class="GtkSpinButton" id="memsize_spin"><property name="visible">True</property><property name="halign">end</property><property name="adjustment">memsize_adj</property><property name="numeric">True</property></object><packing><property name="left-attach">1</property><property name="top-attach">3</property></packing></child>
                              </object>
                            </child>
                          </object>
                          <packing><property name="expand">False</property><property name="fill">True</property><property name="position">1</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child type="tab"><object class="GtkLabel"><property name="visible">True</property><property name="label" translatable="yes">Display</property></object></child>

            <child>
              <object class="GtkScrolledWindow">
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="shadow-type">etched-in</property>
                <child>
